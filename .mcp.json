{
  "gitnexus": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "gitnexus@latest", "mcp"],
    "includeTools": [
      "list_repos",
      "query",
      "context",
      "impact",
      "api_impact",
      "route_map",
      "shape_check",
      "detect_changes"
    ]
  },
  "MCP_DOCKER": {
    "type": "stdio",
    "command": "docker",
    "args": ["mcp", "gateway", "run"],
    "includeTools": ["resolve-library-id", "get-library-docs", "web_search_exa"]
  },
  "morph-mcp": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@morphllm/morphmcp"],
    "env": {
      "ENABLED_TOOLS": "warpgrep_codebase_search"
    },
    "includeTools": ["warpgrep_codebase_search"]
  }
}