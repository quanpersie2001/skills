{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/hooks/session-start.mjs\"",
            "statusMessage": "Pulse: session bootstrap"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/hooks/pre-tool-use.mjs\"",
            "statusMessage": "Pulse: shell guardrails"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/hooks/stop.mjs\"",
            "statusMessage": "Pulse: end-of-turn check"
          }
        ]
      }
    ]
  }
}
